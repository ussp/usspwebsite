{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "partners/tranzin/website/Dockerfile"
  },
  "deploy": {
    "startCommand": "exec caddy run --config /etc/caddy/Caddyfile --adapter caddyfile",
    "healthcheckPath": "/",
    "restartPolicyType": "ALWAYS"
  }
}
